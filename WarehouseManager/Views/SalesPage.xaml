<Page x:Class="WarehouseManager.Views.SalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Értékesítés" Background="#F4F7F9">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Elérhető Termékek" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>
                <DataGrid ItemsSource="{Binding Products}" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Név" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Készlet" Binding="{Binding StockLevel}" Width="60"/>
                        <DataGridTextColumn Header="Ár" Binding="{Binding Price, StringFormat={}{0:N0} Ft}" Width="90"/>
                        <DataGridTemplateColumn Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Kosárba" Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" Background="#3498DB" Foreground="White" BorderThickness="0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="10,0,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="🛒 Kosár" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,15,0,0">
                    <Separator Margin="0,0,0,10"/>
                    <DockPanel Margin="0,0,0,15">
                        <TextBlock Text="Összesen:" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CartTotal, StringFormat={}{0:N0} Ft}" FontSize="22" FontWeight="Bold" Foreground="#27AE60" HorizontalAlignment="Right"/>
                    </DockPanel>
                    <Button Content="FIZETÉS" Command="{Binding CheckoutCommand}" Background="#27AE60" Foreground="White" Height="50" FontSize="18" FontWeight="Bold" BorderThickness="0"/>
                    <Button Content="Kosár űrítése" Command="{Binding ClearCartCommand}" Background="Transparent" Foreground="#E74C3C" BorderThickness="0" Margin="0,10,0,0"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding CartItems}" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5" Width="250">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding Price, StringFormat={}{0:N0} Ft}" HorizontalAlignment="Right" FontSize="14"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Page>