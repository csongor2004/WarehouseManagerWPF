<Page x:Class="WarehouseManager.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Bejelentkezés" Background="Transparent">

    <Page.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="WMS PRO" FontSize="28" FontWeight="ExtraBold" Margin="0,0,0,5" HorizontalAlignment="Center" Foreground="#1E293B"/>
        <TextBlock Text="Üdvözlünk újra! Jelentkezz be." FontSize="14" Margin="0,0,0,30" HorizontalAlignment="Center" Foreground="#64748B"/>

        <TextBlock Text="Felhasználónév" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
        <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15">
            <TextBox x:Name="txtUsername" Background="Transparent" BorderThickness="0" Padding="12" FontSize="14"/>
        </Border>

        <TextBlock Text="Jelszó" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
        <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Margin="0,0,0,25">
            <PasswordBox x:Name="txtPassword" Background="Transparent" BorderThickness="0" Padding="12" FontSize="14"/>
        </Border>

        <Button Content="BELÉPÉS" Click="Login_Click" Background="#3B82F6" Style="{StaticResource ModernButton}"/>

        <Button Content="Nincs még fiókod? Regisztrálj" Click="Register_Click" Background="Transparent" Foreground="#3B82F6" BorderThickness="0" Margin="0,15,0,0" Cursor="Hand" FontWeight="SemiBold"/>
    </StackPanel>
</Page>