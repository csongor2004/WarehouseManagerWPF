<Page x:Class="WarehouseManager.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Bejelentkezés" Background="#F4F7F9">
    <StackPanel Margin="30">
        <TextBlock Text="WMS PRO" FontSize="24" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center" Foreground="#2C3E50"/>
        <TextBlock Text="Kérjük, jelentkezzen be" FontSize="12" Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="Gray"/>

        <TextBlock Text="Felhasználónév:" Margin="0,5"/>
        <TextBox x:Name="txtUsername" Margin="0,0,0,15" Padding="5"/>

        <TextBlock Text="Jelszó:" Margin="0,5"/>
        <PasswordBox x:Name="txtPassword" Margin="0,0,0,20" Padding="5"/>

        <Button Content="BELÉPÉS" Click="Login_Click" Background="#3498DB" Foreground="White" Height="40" FontWeight="Bold"/>
        <Button Content="Nincs fiókom? Regisztráció" Click="Register_Click" Background="Transparent" Foreground="#3498DB" BorderThickness="0" Margin="0,10,0,0"/>
    </StackPanel>
</Page>