<Page x:Class="WarehouseManager.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Regisztráció" Background="#F4F7F9">
    <StackPanel Margin="30">
        <TextBlock Text="Új fiók létrehozása" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="#2C3E50"/>

        <TextBlock Text="Felhasználónév:" Margin="0,5"/>
        <TextBox x:Name="txtRegUsername" Margin="0,0,0,15" Padding="5"/>

        <TextBlock Text="Jelszó:" Margin="0,5"/>
        <PasswordBox x:Name="txtRegPassword" Margin="0,0,0,20" Padding="5"/>

        <Button Content="REGISZTRÁCIÓ" Click="RegisterSave_Click" Background="#27AE60" Foreground="White" Height="40" FontWeight="Bold"/>

        <Button Content="Mégse, vissza a belépéshez" Click="BackToLogin_Click" Background="Transparent" Foreground="#7F8C8D" BorderThickness="0" Margin="0,10,0,0"/>
    </StackPanel>
</Page>