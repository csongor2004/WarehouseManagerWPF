<Page x:Class="WarehouseManager.Views.StatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Statisztika">
    <Grid Margin="30">
        <TextBlock Text="Raktárkészlet Vizualizáció" FontSize="26" FontWeight="Bold" Margin="0,0,0,30" Foreground="#2C3E50"/>

        <ScrollViewer Margin="0,50,0,0">
            <ItemsControl ItemsSource="{Binding Products}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14"/>

                            <ProgressBar Grid.Column="1" Value="{Binding StockLevel}" Maximum="100" Height="22" 
                                         Foreground="#3498DB" Background="#ECF0F1" BorderThickness="0"/>

                            <TextBlock Grid.Column="2" Text="{Binding StockLevel}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="14" FontWeight="Bold"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>