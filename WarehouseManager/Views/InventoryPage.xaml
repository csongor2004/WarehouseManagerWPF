<Page x:Class="WarehouseManager.Views.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Raktárkészlet">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,20">
            <Border Background="White" Margin="5" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Összes termék" Foreground="Gray"/>
                    <TextBlock Text="{Binding Products.Count}" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="White" Margin="5" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Raktár érték" Foreground="Gray"/>
                    <TextBlock Text="Aktív" FontSize="24" FontWeight="Bold" Foreground="#27AE60"/>
                </StackPanel>
            </Border>
            <Border Background="White" Margin="5" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Alacsony készlet" Foreground="Gray"/>
                    <TextBlock Text="Figyelés bekapcsolva" FontSize="18" FontWeight="SemiBold" Foreground="#E74C3C"/>
                </StackPanel>
            </Border>
        </UniformGrid>
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBox Width="250" VerticalContentAlignment="Center" Padding="5" Tag="Keresés..."/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="+ Új Termék" Command="{Binding AddProductCommand}" Background="#27AE60" Foreground="White" Padding="15,5"/>
                <Button Content="Törlés" Command="{Binding DeleteProductCommand}" Background="#E74C3C" Foreground="White" Margin="10,0,0,0" Padding="15,5"/>
            </StackPanel>
        </DockPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}"
          AutoGenerateColumns="False" CanUserAddRows="False" Background="White" RowHeight="40">

            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditProductCommand}"/>
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="100"/>
                <DataGridTextColumn Header="Név" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Készlet" Binding="{Binding StockLevel}" Width="80"/>
                <DataGridTextColumn Header="Ár" Binding="{Binding Price, StringFormat={}{0:N0} Ft}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>