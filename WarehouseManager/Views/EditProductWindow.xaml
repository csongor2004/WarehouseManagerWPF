<Window x:Class="WarehouseManager.Views.EditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Termék Szerkesztése" Height="400" Width="350" WindowStartupLocation="CenterOwner" Background="#F4F7F9">
    <StackPanel Margin="20">
        <TextBlock Text="Termék módosítása" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>

        <TextBlock Text="Név:" Margin="0,5"/>
        <TextBox x:Name="txtName" Margin="0,0,0,10" Padding="5"/>

        <TextBlock Text="SKU (Azonosító):" Margin="0,5"/>
        <TextBox x:Name="txtSKU" Margin="0,0,0,10" Padding="5"/>

        <TextBlock Text="Készlet:" Margin="0,5"/>
        <TextBox x:Name="txtStock" Margin="0,0,0,10" Padding="5"/>

        <TextBlock Text="Ár (Ft):" Margin="0,5"/>
        <TextBox x:Name="txtPrice" Margin="0,0,0,10" Padding="5"/>

        <Button Content="Módosítások Mentése" Click="Save_Click" Background="#F39C12" Foreground="White" FontWeight="Bold" Height="40" Margin="0,10"/>
    </StackPanel>
</Window>