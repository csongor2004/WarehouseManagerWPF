<Window x:Class="WarehouseManager.Views.EditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Termék Módosítása" Height="480" Width="380" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#E2E8F0" WindowStyle="ToolWindow">

    <Grid>
        <Border Background="White" Margin="20" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel Margin="25">
                <TextBlock Text="✏️ Termék Szerkesztése" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <TextBlock Text="Termék neve" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                <Border Background="#F1F5F9" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                    <TextBox x:Name="txtName" Background="Transparent" BorderThickness="0" FontSize="14"/>
                </Border>

                <TextBlock Text="SKU (Azonosító)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                <Border Background="#F1F5F9" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                    <TextBox x:Name="txtSKU" Background="Transparent" BorderThickness="0" FontSize="14"/>
                </Border>

                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Készlet (db)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                        <Border Background="#F1F5F9" CornerRadius="6" Padding="10">
                            <TextBox x:Name="txtStock" Background="Transparent" BorderThickness="0" FontSize="14"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Ár (Ft)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                        <Border Background="#F1F5F9" CornerRadius="6" Padding="10">
                            <TextBox x:Name="txtPrice" Background="Transparent" BorderThickness="0" FontSize="14"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <Button Content="MÓDOSÍTÁSOK MENTÉSE" Click="Save_Click" Background="#3B82F6" Foreground="White" FontWeight="Bold" Height="42" Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>