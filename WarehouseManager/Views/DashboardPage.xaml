<Page x:Class="WarehouseManager.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Vezérlőpult">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📊 Rendszer Áttekintés" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,20">

            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,15,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Katalógus mérete" Foreground="#64748B" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalProductsCount}" FontSize="32" FontWeight="Bold" Foreground="#3B82F6" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="20" Margin="7.5,0,7.5,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Teljes Készletérték" Foreground="#64748B" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalInventoryValue, StringFormat={}{0:N0} Ft}" FontSize="32" FontWeight="Bold" Foreground="#10B981" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="12" Padding="20" Margin="15,0,0,0">
                <StackPanel>
                    <TextBlock Text="Kritikus Készletszint (&lt; 5 db)" Foreground="#EF4444" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LowStockCount}" FontSize="32" FontWeight="Bold" Foreground="#DC2626" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="⚠️ Újrarendelést igénylő termékek" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                <DataGrid ItemsSource="{Binding LowStockProducts}" AutoGenerateColumns="False" IsReadOnly="True" 
                          BorderThickness="0" Background="White" RowHeight="40" GridLinesVisibility="None" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="100"/>
                        <DataGridTextColumn Header="TERMÉKNÉV" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="KÉSZLET" Binding="{Binding StockLevel}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</Page>