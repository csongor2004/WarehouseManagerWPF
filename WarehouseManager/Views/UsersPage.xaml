<Page x:Class="WarehouseManager.Views.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Felhasználók">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Dolgozók és Jogosultságok" FontSize="22" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="⬆️ Kinevezés Adminná" Command="{Binding PromoteUserCommand}" Background="#3B82F6" Foreground="White" FontWeight="Bold" Padding="15,8" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="⬇️ Jogosultság elvétele" Command="{Binding DemoteUserCommand}" Background="#64748B" Foreground="White" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding UsersList}" SelectedItem="{Binding SelectedUser}" 
          AutoGenerateColumns="False" CanUserAddRows="False" 
          BorderThickness="0" Background="White" RowHeight="45" 
          GridLinesVisibility="None" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="FELHASZNÁLÓNÉV" Binding="{Binding Username}" Width="*" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="SZEREPKÖR (ROLE)" Binding="{Binding Role}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>