<Page x:Class="WarehouseManager.Views.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Felhasználók">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>
            <TextBlock Text="Dolgozók és Jogosultságok" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding UsersList}" AutoGenerateColumns="False" CanUserAddRows="False" 
                      BorderThickness="0" RowHeight="45" HeadersVisibility="Column" GridLinesVisibility="None">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="FELHASZNÁLÓNÉV" Binding="{Binding Username}" Width="*" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="SZEREPKÖR (ROLE)" Binding="{Binding Role}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>