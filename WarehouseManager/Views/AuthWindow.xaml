<Window x:Class="WarehouseManager.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WMS Hitelesítés" Height="550" Width="400" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#E2E8F0" WindowStyle="ToolWindow">

    <Grid>
        <Border Background="White" Margin="30,40" CornerRadius="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.1" Color="Black"/>
            </Border.Effect>

            <Frame x:Name="AuthFrame" NavigationUIVisibility="Hidden" Margin="10"/>
        </Border>
    </Grid>
</Window>