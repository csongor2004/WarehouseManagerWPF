<Window x:Class="WarehouseManager.Views.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Új Termék" Height="400" Width="350" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock Text="Név:" Margin="0,5"/>
        <TextBox x:Name="txtName" Margin="0,0,0,10"/>

        <TextBlock Text="SKU (Azonosító):" Margin="0,5"/>
        <TextBox x:Name="txtSKU" Margin="0,0,0,10"/>

        <TextBlock Text="Készlet:" Margin="0,5"/>
        <TextBox x:Name="txtStock" Margin="0,0,0,10"/>

        <TextBlock Text="Ár (Ft):" Margin="0,5"/>
        <TextBox x:Name="txtPrice" Margin="0,0,0,10"/>

        <Button Content="Mentés" Click="Save_Click" Background="#27AE60" Foreground="White" Height="40" Margin="0,10"/>
    </StackPanel>
</Window>