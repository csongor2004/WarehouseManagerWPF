<Window x:Class="WarehouseManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Warehouse Manager Pro" Height="700" Width="1100"
        Background="#F4F7F9" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="10">
                <TextBlock Text="WMS PRO" Foreground="White" FontSize="22" FontWeight="Bold" Margin="10,20"/>
                <Separator Background="#34495E" Margin="0,10"/>

                <Button Content="📦 Raktárkészlet" Command="{Binding NavInventoryCommand}" 
                        Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Foreground="White" Padding="10" Margin="0,5"/>
                <Button Content="📊 Statisztika" Foreground="White" Padding="10" Margin="0,5" 
                        Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                <Button Content="📥 CSV Export" Command="{Binding ExportCsvCommand}" 
                        Background="#3498DB" Foreground="White" Margin="0,20,0,0" Padding="10"/>
            </StackPanel>
        </Border>

        <Frame Grid.Column="1" Content="{Binding CurrentPage}" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>