<Window x:Class="WarehouseManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Warehouse Manager Pro" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F4F7F9">

    <Window.Resources>
        <Style TargetType="Button" x:Key="MenuButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E293B" CornerRadius="0,20,20,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
            </Border.Effect>

            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="20,30,20,20" HorizontalAlignment="Center">
                    <Border Width="60" Height="60" CornerRadius="30" Background="#3B82F6" Margin="0,0,0,10">
                        <TextBlock Text="👤" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                    </Border>
                    <TextBlock Text="{Binding CurrentUserName}" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="WMS Rendszer" Foreground="#94A3B8" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Background="#334155" Margin="20,0,20,20"/>

                <Button DockPanel.Dock="Bottom" Content="Kijelentkezés" Command="{Binding LogoutCommand}" 
        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
        Style="{StaticResource MenuButton}" Foreground="#EF4444" Margin="10,20"/>

                <StackPanel>
                    <Button Content="🏠 Vezérlőpult" Command="{Binding NavDashboardCommand}" Style="{StaticResource MenuButton}"/>
                    <Button Content="📦 Raktárkészlet" Command="{Binding NavInventoryCommand}" Style="{StaticResource MenuButton}"/>
                    <TextBlock DockPanel.Dock="Top" Text="Elérhető Termékek" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>

                    <Border DockPanel.Dock="Top" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="2" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📠 Vonalkód (SKU) leolvasása:" FontWeight="Bold" Foreground="#1D4ED8" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <TextBox Grid.Column="1" Text="{Binding BarcodeText, UpdateSourceTrigger=PropertyChanged}" Background="White" BorderThickness="0" Padding="10" FontSize="16">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding ProcessBarcodeCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>
                    </Border>

                    <DataGrid ItemsSource="{Binding Products}" ... >```

